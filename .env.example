# ParkPro - Variables de Entorno
# Copia este archivo como .env y completa los valores

# ============================================
# DATABASE - PostgreSQL (requerido)
# ============================================
DB_PASSWORD=ParkPro2024Secure!

# ============================================
# JWT - Autenticación (cambiar en producción)
# ============================================
JWT_SECRET=your-super-secret-jwt-key-change-in-production-at-least-32-chars
JWT_EXPIRATION=8h

# ============================================
# Node Environment
# ============================================
NODE_ENV=development

# ============================================
# Swagger - Documentación API
# ============================================
SWAGGER_PATH=/api/docs

# ============================================
# URLs - Configuración de servicios
# ============================================
VITE_API_URL=http://localhost:3000/api
VITE_WS_URL=ws://localhost:3000

# ============================================
# Puerto del servidor
# ============================================
PORT=3000
